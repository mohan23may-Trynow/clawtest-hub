{
  "name": "clawtest-hub",
  "version": "0.1.0",
  "description": "Verify whether an OpenClaw agent is actually contained before you trust it with real files.",
  "type": "module",
  "bin": {
    "clawtest-hub": "dist/cli.js"
  },
  "engines": {
    "node": ">=18.19"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "openclaw",
    "agent",
    "sandbox",
    "security",
    "cli"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
