{
  "name": "clawtest-hub",
  "version": "0.1.0",
  "description": "Verify whether an OpenClaw agent is actually contained before you trust it with real files.",
  "type": "module",
  "bin": {
    "clawtest-hub": "dist/cli.js"
  },
  "engines": {
    "node": ">=18.19"
  },
  "files": [
    "dist",
    "examples",
    "docs",
    "README.md",
    "LICENSE",
    "NOTICE",
    "SECURITY.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mohan23may-Trynow/clawtest-hub.git"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "openclaw",
    "agent",
    "sandbox",
    "security",
    "cli"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "commander": "^12.1.0",
    "execa": "^9.5.2",
    "picocolors": "^1.1.1",
    "yaml": "^2.6.1",
    "zod": "^3.24.1"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^3.2.6"
  }
}
