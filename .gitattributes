# Normalize all text files to LF in the repository, on every OS.
* text=auto eol=lf

# Known binary types — never normalize or diff as text.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.pdf  binary
*.zip  binary
*.gz   binary
*.tgz  binary
*.woff  binary
*.woff2 binary
