# Secrets — NEVER commit these.
# Match real secret-bearing ARTIFACTS (keys, tokens, env, the OpenClaw config), NOT any
# source/recipe file whose NAME merely contains "secret"/"credential". The old broad
# *secret*/*credentials* substring globs silently swallowed legitimate files like
# examples/preflight/no-secret-echo.yaml and src/run/secrets.ts (which hold code + benign
# decoys, e.g. the AWS doc key AKIAIOSFODNN7EXAMPLE). Keep these patterns narrow.
.env
.env.*
*.token
*.pem
*.key
*.p12
*.pfx
id_rsa
id_ed25519
secrets.local.*
credentials.json
# OpenClaw config can contain the gateway token — never copy it into the repo
openclaw.json

# Node
node_modules/
dist/
build/
*.log
npm-debug.log*

# Test output
/out/
*.report.json
.sandbox-tmp/

# OS / editor
.DS_Store
Thumbs.db
.vscode/
.idea/
